# Default: local demo mode for team development without MySQL.
DB_BACKEND=sqlite
SQLITE_PATH=data_samples/demo.sqlite3

# MySQL settings. Use these for final/shared DB mode.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=oil_car_app

# Optional: https://www.opinet.co.kr/user/custapi/custApiInfo.do
# In production/shared mode, the operator can set this key internally.
OPINET_API_KEY=
